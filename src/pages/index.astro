---
import BaseLayout from '../layouts/BaseLayout.astro';
import CustomerIdentification from '../components/CustomerIdentification';

const email = Astro.url.searchParams.get('email') || '';
---

<BaseLayout title={email ? `${email} — Hercules CRM` : 'Hercules CRM'}>
  <header class="bg-[#253461] border-b border-[#1c2847] px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-[#10c99e] rounded-lg flex items-center justify-center text-white font-bold text-sm font-[Jost,sans-serif]">H</div>
      <h1 class="text-lg font-semibold text-white font-[Jost,sans-serif]">Hercules CRM</h1>
    </div>
    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-4">
        <a href="/products" class="text-sm text-gray-300 hover:text-white transition-colors">Products</a>
      </nav>
      {email && (
        <span class="text-sm text-gray-300 ml-2">{email}</span>
      )}
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-6 py-8">
    {email ? (
      <CustomerIdentification email={email} client:load />
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold mb-2">No customer selected</h2>
        <p class="text-gray-500">Open this dashboard from the Missive sidebar to identify a customer.</p>
      </div>
    )}
  </main>
</BaseLayout>
